# .env.example — committed no git como documentação
# Copie este arquivo para .env e preencha com valores reais
# Ver briefing_06_adendo_env.md para detalhes

# === Reaproveitadas do v2 ===
ANTHROPIC_API_KEY=sk-ant-coloque-sua-chave
APIFY_TOKEN=apify_api_coloque-seu-token
OPENAI_API_KEY=sk-coloque-sua-chave-se-aplicavel

# === Flask + banco ===
FLASK_ENV=development
FLASK_PORT=5050
DATABASE_URL=sqlite:///pdpa_v3_dev.db
FLASK_SECRET_KEY=gerar-com-secrets-token-urlsafe-32
JWT_SECRET_KEY=gerar-com-secrets-token-urlsafe-32
JWT_EXPIRATION_HOURS=24
FERNET_KEY=gerar-com-Fernet-generate-key

# === Classifier — escalada Haiku→Sonnet (Bloco 3.1) ===
# Threshold de confiança abaixo do qual a escalada para Sonnet considera disparar.
CLASSIFIER_ESCALATION_THRESHOLD=0.6
# Teto de gasto mensal com Sonnet — quando atingido, escalada é suprimida.
CLASSIFIER_MONTHLY_BUDGET_USD=50.0
# Kill switch global da escalada.
CLASSIFIER_ESCALATION_ENABLED=true
# Modelo Sonnet usado quando a escalada dispara.
CLASSIFIER_SONNET_MODEL=claude-sonnet-4-5-20250929

# === Coleta — janela e overrides (Bloco 4 CP-D) ===
# Janela de coleta default em meses: usada quando a Fonte é nova
# (sem verbatins anteriores) E sem override explícito. Filtro vai pro
# Apify como ``reviewsStartDate = hoje − N meses``.
PDPA_COLETA_JANELA_MESES=15
# Override GLOBAL da data inicial (substitui o cálculo "hoje − N meses").
# Use quando quiser fixar uma data de corte para todas as fontes novas.
# Formato: YYYY-MM-DD. Comentar para usar PDPA_COLETA_JANELA_MESES.
# PDPA_COLETA_DESDE=2025-01-01
# Override de EXECUÇÃO: ignora o cálculo incremental por fonte e força
# esta data como reviewsStartDate. Útil para testes e re-coletas.
# Formato: YYYY-MM-DD. Comentar fora do contexto de teste.
# PDPA_COLETA_DESDE_OVERRIDE=2025-06-01

# === Manutenção do banco (Bloco 4 CP-D) ===
# Janela de retenção em meses para o comando ``flask retencao-aplicar``.
# Verbatins com data_criacao_original mais antiga são removidos.
# Recomenda-se 18 meses (cobre comparações YoY + margem).
PDPA_RETENCAO_MESES=18
